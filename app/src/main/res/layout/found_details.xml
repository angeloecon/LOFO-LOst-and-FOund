<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- Professional Gradient Header -->
    <View
        android:id="@+id/headerBackground"
        android:layout_width="0dp"
        android:layout_height="300dp"
        android:background="@drawable/gradient_header"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Subtle Pattern Texture -->

    <!-- Top Status Bar -->
    <View
        android:id="@+id/statusBar"
        android:layout_width="0dp"
        android:layout_height="4dp"
        android:background="@drawable/accent_gradient"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Back Button - Minimal & Professional -->
    <Button
        android:id="@+id/backBtn"
        style="?android:attr/borderlessButtonStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/back_button_bg"
        android:drawableLeft="@android:drawable/ic_menu_revert"
        android:drawablePadding="6dp"
        android:drawableTint="#FFFFFF"
        android:elevation="4dp"
        android:paddingStart="12dp"
        android:paddingTop="10dp"
        android:paddingEnd="16dp"
        android:paddingBottom="10dp"
        android:text="Back"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Item Image Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/imageCard"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_marginTop="70dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/img"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/lavendar_border"
            android:scaleType="centerCrop"
            tools:srcCompat="@tools:sample/avatars" />
    </androidx.cardview.widget.CardView>

    <!-- MAIN CONTENT CARD -->
    <androidx.cardview.widget.CardView
        android:id="@+id/contentCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="260dp"
        android:layout_marginBottom="90dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="16dp"
        app:cardElevation="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/input_border_rounded"
                android:orientation="vertical"
                android:padding="24dp"
                android:paddingTop="32dp">

                <!-- Title Section - Bold & Professional -->
                <TextView
                    android:id="@+id/titleText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ITEM"
                    android:textColor="#9E9E9E"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15" />

                <TextView
                    android:id="@+id/title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="24dp"
                    android:textColor="#212121"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    tools:text="Found Item Name" />

                <!-- Category with Icon -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="40dp"
                        android:background="@drawable/category_accent" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/categoryText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CATEGORY"
                            android:textColor="#757575"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.12" />

                        <TextView
                            android:id="@+id/category"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textColor="#424242"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            tools:text="Electronics" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Location Section -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="40dp"
                        android:background="@drawable/location_accent" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/addressText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="LOCATION"
                            android:textColor="#757575"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.12" />

                        <TextView
                            android:id="@+id/address"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textColor="#424242"
                            android:textSize="15sp"
                            tools:text="Location where found" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Date & Time Grid -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:background="@drawable/datetime_container_bg"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:weightSum="2">

                    <!-- Date -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/dateFoundText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:drawableLeft="@android:drawable/ic_menu_my_calendar"
                            android:drawablePadding="8dp"
                            android:drawableTint="#8B2332"
                            android:text="DATE"
                            android:textColor="#757575"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.12" />

                        <TextView
                            android:id="@+id/dateFound"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="#212121"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            tools:text="10/10/2024" />
                    </LinearLayout>

                    <!-- Vertical Divider -->
                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:layout_marginHorizontal="12dp"
                        android:background="#E0E0E0" />

                    <!-- Time -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/timeFoundText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:drawableLeft="@android:drawable/ic_menu_recent_history"
                            android:drawablePadding="8dp"
                            android:drawableTint="#2E5C8A"
                            android:text="TIME"
                            android:textColor="#757575"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.12" />

                        <TextView
                            android:id="@+id/timeFound"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="#212121"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            tools:text="10:30 AM" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Description Section -->
                <TextView
                    android:id="@+id/descriptionText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DESCRIPTION"
                    android:textColor="#757575"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12" />

                <TextView
                    android:id="@+id/description"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="28dp"
                    android:lineSpacingExtra="4dp"
                    android:textColor="#616161"
                    android:textSize="15sp"
                    tools:text="A brief description of the item found. This section provides additional details about the item's condition, features, and any other relevant information." />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginBottom="24dp"
                    android:background="#E0E0E0" />

                <!-- Finder Information Header -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:text="FINDER INFORMATION"
                    android:textColor="#212121"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12" />

                <!-- Finder Details Grid -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/finder_info_bg"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Finder Name -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/icon_circle_bg" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/finderNameText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="FINDER"
                                android:textColor="#757575"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.12" />

                            <TextView
                                android:id="@+id/finderName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:textColor="#212121"
                                android:textSize="17sp"
                                android:textStyle="bold"
                                tools:text="Shruti Sharma" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Email -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/icon_circle_bg_alt" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/mailtext"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="EMAIL"
                                android:textColor="#757575"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.12" />

                            <TextView
                                android:id="@+id/mail"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:textColor="#424242"
                                android:textSize="15sp"
                                tools:text="finder@example.com" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </androidx.cardview.widget.CardView>

    <!-- Professional Action Buttons -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/action_buttons_container"
        android:elevation="8dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="12dp"
        android:weightSum="2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Call Button -->
        <!-- CALL -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/call"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/button_call_professional"
            android:text="CALL"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="14sp"
            android:drawableLeft="@android:drawable/ic_menu_call"
            android:drawableTint="#FFFFFF"
            android:drawablePadding="8dp"
            android:backgroundTint="@null"
            android:stateListAnimator="@null" />
        <!-- SMS Button -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/sms"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/button_sms_professional"
            android:drawableLeft="@android:drawable/sym_action_chat"
            android:drawablePadding="8dp"
            android:drawableTint="#FFFFFF"
            android:stateListAnimator="@null"
            android:text="MESSAGE"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>